# Copy this file to .env and fill in your credentials.
# The .env file is gitignored so your real values never get committed.

# Alpaca paper trading account: sign up free at https://alpaca.markets/
# Generate keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_paper_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Absolute path to where SQLite should store the database file.
DB_FILE=/absolute/path/to/your/app.db

# Gmail app password (NOT your regular Gmail password) for trade notifications.
# Generate one at https://myaccount.google.com/apppasswords after enabling 2FA.
# Leave EMAIL_ADDRESS blank to disable email notifications cleanly — the strategy
# scripts have a graceful-degradation check that skips SMTP when creds are missing.
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Optional overrides — these all have sensible defaults in config.py.
# Uncomment and edit only if you need to override them.
# ALPACA_API_URL=https://paper-api.alpaca.markets
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
