# Virtual Environment - CRITICAL!
venv/
.venv/
env/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyo
*.pyd
*.python-version

# Database
*.db
*.sqlite
*.sqlite3

# Secrets
# config.py is NOT gitignored anymore — it reads from env vars (no secrets in it).
# The actual secrets live in .env (local) or the cloud platform's secret store (prod).
.env
.env.local
.env.*.local
*.key
*.pem

# Logs
*.log
*.log.*
logs/
logs_backup_*.txt

# SQLite browser project file
*.sqbpro

# Personal engineering notes (not for the public repo)
notes/

# Pytest / coverage artifacts (when tests get added)
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Linter / type-checker caches
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Python packaging artifacts
*.egg-info/
dist/
build/
*.egg
*.whl

# Back-test output dumps
output.txt
output_*.txt

# Local editor scratch files
*.bak
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# VS Code
.vscode/
*.code-workspace

# IDE
